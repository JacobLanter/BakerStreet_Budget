# -----------------------------------------------------------------------------
# YNAB_Dashboard - Example Environment Configuration
# -----------------------------------------------------------------------------
# Copy this file to `.env` and fill in the values for your local setup.
# Never commit your real `.env` file to version control.
#
# Example (PowerShell):
#   Copy-Item .env.example .env
#
# Example (bash):
#   cp .env.example .env
# -----------------------------------------------------------------------------

# ============================================================================
# YNAB API CONFIGURATION
# ============================================================================

# Your personal YNAB API access token.
# Generate from: https://api.youneedabudget.com
YNAB_API_TOKEN=your-ynab-api-token-here

# The default budget ID to pull data from.
# You can find this in the URL when viewing a budget in YNAB.
YNAB_BUDGET_ID=your-budget-id-here

# Optional: Base URL for the YNAB API (usually leave as default).
YNAB_API_BASE_URL=https://api.ynab.com/v1

# ============================================================================
# ELASTICSEARCH CONFIGURATION
# ============================================================================

# Connection URL for Elasticsearch.
# For a local Docker setup, this might be: http://elasticsearch:9200
ELASTICSEARCH_URL=http://localhost:9200

# Set password for user elastic which is created by default in Elasticsearch
ELASTICSEARCH_PASSWORD=at least six characters long

# Name of the index where processed YNAB metrics will be stored.
ELASTICSEARCH_INDEX=ynab_dashboard_metrics


# ============================================================================
# KIBANA / DASHBOARD CONFIGURATION
# ============================================================================

# Public URL of Kibana used to visualize the metrics.
# For a local Docker setup, this might be: http://kibana:5601
KIBANA_URL=http://localhost:5601
KIBANA_SYSTEM_PASSWORD=at least six characters long
KIBANA_ENCRYPTION_KEY=Create Key using command "openssl rand -base64 32" in linux or wsl==

# ============================================================================
# SECURITY / DEPLOYMENT NOTES
# ============================================================================
# - Do NOT commit your real `.env` to git.
# - Treat API tokens and passwords like passwords.
# - For any production-like environment, consider using a secrets manager
#   (e.g. 1Password, Vault, AWS Secrets Manager) instead of a plain .env file.

